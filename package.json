{
  "name": "fun-london-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"*.{ts,tsx,json,js}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"*.{ts,tsx,json,js}\"",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "ingest:dry": "tsx scripts/ingest-venues.ts --dry-run",
    "ingest": "tsx scripts/ingest-venues.ts",
    "refresh-venues:dry": "tsx scripts/refresh-venues.ts --dry-run",
    "refresh-venues": "tsx scripts/refresh-venues.ts",
    "ingest-events:dry": "tsx scripts/ingest-events.ts --dry-run",
    "ingest-events": "tsx scripts/ingest-events.ts",
    "scout-candidates:dry": "tsx scripts/scout-candidates.ts --dry-run",
    "scout-candidates": "tsx scripts/scout-candidates.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@vercel/analytics": "^1.3.1",
    "lucide-react": "^1.14.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x"
  }
}
