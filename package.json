{
  "name": "fun-london-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"*.{ts,tsx,json,js}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\" \"*.{ts,tsx,json,js}\"",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm check:copy && pnpm test",
    "check:copy": "tsx scripts/check-no-dashes.ts",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "ingest:dry": "tsx scripts/ingest-venues.ts --dry-run",
    "ingest": "tsx scripts/ingest-venues.ts",
    "refresh-venues:dry": "tsx scripts/refresh-venues.ts --dry-run",
    "refresh-venues": "tsx scripts/refresh-venues.ts",
    "refresh-reviews:dry": "tsx scripts/refresh-reviews.ts --dry-run",
    "refresh-reviews": "tsx scripts/refresh-reviews.ts",
    "ingest-events:dry": "tsx scripts/ingest-events.ts --dry-run",
    "ingest-events": "tsx scripts/ingest-events.ts",
    "ingest:from-pending:dry": "tsx scripts/ingest-from-pending.ts --dry-run",
    "ingest:from-pending": "tsx scripts/ingest-from-pending.ts",
    "backfill:tags:dry": "tsx scripts/backfill-canonical-tags.ts --dry-run",
    "backfill:tags": "tsx scripts/backfill-canonical-tags.ts",
    "scout-candidates:dry": "tsx scripts/scout-candidates.ts --dry-run",
    "scout-candidates": "tsx scripts/scout-candidates.ts",
    "discover-venues:dry": "tsx scripts/discover-venues.ts --dry-run",
    "discover-venues": "tsx scripts/discover-venues.ts",
    "discover-popups:dry": "tsx scripts/discover-popups.ts --dry-run",
    "discover-popups": "tsx scripts/discover-popups.ts",
    "send-weekly-digest:dry": "tsx scripts/send-weekly-digest.ts --dry",
    "send-weekly-digest:preview": "tsx scripts/send-weekly-digest.ts --preview",
    "send-weekly-digest": "tsx scripts/send-weekly-digest.ts",
    "backfill-photos:dry": "tsx scripts/backfill-photos.ts --dry-run",
    "backfill-photos": "tsx scripts/backfill-photos.ts",
    "backfill-gallery:dry": "tsx scripts/backfill-gallery.ts --dry-run",
    "backfill-gallery": "tsx scripts/backfill-gallery.ts",
    "backfill-maps:dry": "tsx scripts/backfill-maps.ts --dry-run",
    "backfill-maps": "tsx scripts/backfill-maps.ts",
    "backfill-popup-images:dry": "tsx scripts/backfill-popup-images.ts --dry-run",
    "backfill-popup-images": "tsx scripts/backfill-popup-images.ts",
    "verify:sources": "tsx scripts/verify-editorial-sources.ts",
    "verify:sources:write": "tsx scripts/verify-editorial-sources.ts -- --write",
    "verify:sources:curated": "tsx scripts/verify-editorial-sources.ts -- --curated",
    "verify:sources:curated:write": "tsx scripts/verify-editorial-sources.ts -- --write --curated",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "posthog-js": "^1.387.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.3",
    "typescript": "^5.6.2",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x"
  }
}
