# Hoist sharp's platform packages to the root node_modules.
#
# sharp 0.35 split libvips out into separate @img/sharp-libvips-<platform>
# packages, and the compiled @img/sharp-<platform> binary locates it via a
# RELATIVE rpath that assumes the two sit side by side. Under pnpm's default
# isolated layout they land in different store directories, so dlopen fails at
# runtime with:
#
#   Could not load the "sharp" module using the <platform> runtime
#   ERR_DLOPEN_FAILED: Library not loaded: @rpath/libvips-cpp.8.18.3.dylib
#
# Hoisting @img/* puts them adjacent again. Without this, every script that
# touches sharp (R2 photo migration, photo-storage) fails, and so do their
# tests. Remove only if sharp goes back to bundling libvips.
public-hoist-pattern[]=@img/*
