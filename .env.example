# ── Core (required) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Ingestion scripts (server-only; never expose service role on Vercel) ─────
GOOGLE_PLACES_API_KEY=AIza...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
GEMINI_API_KEY=AIza...

# ── Photo Storage mirroring (optional; closes the exposed-Places-key issue) ──
# Name of a PUBLIC Supabase Storage bucket. When set, the ingest/discover
# scripts download Google photos and re-host them here (keyless URLs). Leave
# blank to keep the legacy keyed Google URLs. See scripts/photo-storage.ts.
FL_PHOTO_BUCKET=

# ── Affiliate / attribution (optional; revenue. No-op until set) ─────────────
# Paste each programme's approved publisher/affiliate id. See lib/affiliate.ts.
NEXT_PUBLIC_AFFILIATE_OPENTABLE=
NEXT_PUBLIC_AFFILIATE_RESY=
NEXT_PUBLIC_AFFILIATE_SEVENROOMS=
NEXT_PUBLIC_AFFILIATE_THEFORK=
NEXT_PUBLIC_AFFILIATE_TICKETMASTER=

# ── Product analytics (optional; no-op until set) ────────────────────────────
# PostHog Project API Key — PUBLIC and write-only, safe to expose. Get it from
# PostHog → Settings → Project. Host stays on EU cloud for UK/EU data residency.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Admin (fail-closed: unset = nobody is admin) ─────────────────────────────
FL_ADMIN_EMAILS=
