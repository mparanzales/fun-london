# ── Core (required) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Ingestion scripts (server-only; never expose service role on Vercel) ─────
GOOGLE_PLACES_API_KEY=AIza...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Photo Storage mirroring (optional; closes the exposed-Places-key issue) ──
# Name of a PUBLIC Supabase Storage bucket. When set, the ingest/discover
# scripts download Google photos and re-host them here (keyless URLs). Leave
# blank to keep the legacy keyed Google URLs. See scripts/photo-storage.ts.
FL_PHOTO_BUCKET=

# ── Affiliate / attribution (optional; revenue. No-op until set) ─────────────
# Paste each programme's approved publisher/affiliate id. See lib/affiliate.ts.
NEXT_PUBLIC_AFFILIATE_OPENTABLE=
NEXT_PUBLIC_AFFILIATE_RESY=
NEXT_PUBLIC_AFFILIATE_SEVENROOMS=
NEXT_PUBLIC_AFFILIATE_THEFORK=
NEXT_PUBLIC_AFFILIATE_TICKETMASTER=

# ── Product analytics (optional; no-op until set) ────────────────────────────
# PostHog Project API Key — PUBLIC and write-only, safe to expose. Get it from
# PostHog → Settings → Project. Host stays on EU cloud for UK/EU data residency.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Admin (fail-closed: unset = nobody is admin) ─────────────────────────────
FL_ADMIN_EMAILS=

# ── Image hosting: Cloudflare R2 (GitHub Actions secrets) ────────────────────
# Primary photo host. Venue photos are mirrored from Places, re-encoded to
# WebP at two widths and served keylessly from R2_PUBLIC_BASE. Without these,
# scripts/photo-storage.ts falls back to the legacy Supabase Storage bucket
# above (which hit 708% of its 1GB free tier, hence the move).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=fun-london-photos
R2_PUBLIC_BASE=https://img.funldn.com
# Separate PRIVATE bucket for the weekly DB snapshot (backup-db.yml).
R2_BACKUP_BUCKET=

# ── Event providers (GitHub Actions secrets) ─────────────────────────────────
# Without these, events-ingest runs GREEN and ingests NOTHING. Check the step
# summary, not just the tick. Skiddle and DICE adapters are stubs; no keys.
TICKETMASTER_API_KEY=
EVENTBRITE_PRIVATE_TOKEN=

# ── Search rate limiting (Upstash Redis) ─────────────────────────────────────
# Unset falls back to a per-instance in-memory limiter, which is effectively
# no limit on serverless. Watch for a trailing newline when pasting the token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Transactional + digest email (Resend) ────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── Tuning knobs (all optional; sensible defaults in code) ───────────────────
# FL_CENTER=1        Subtract the catalogue centroid in the ranker (lib/ranker.ts)
# HYBRID_W=0.4       Tag weight vs reviews in the hybrid vector
# REFRESH_LIMIT=80   Venues refreshed per maintenance run (Places cost lever)
# FL_REVIEW_BATCH    Venues per review-refresh batch
# BACKFILL_MAX       Cap on rows a backfill script will touch in one run
# MENU_MAX           Cap for discover-menus
# FL_MIGRATE_CONCURRENCY  Parallelism for the R2 photo migration
# FL_STATIC_MAP_ZOOM Zoom level for generated static maps
# BACKUP_DATE        Restore a specific snapshot (see docs/RESTORE.md)

# ── Where each of these belongs ──────────────────────────────────────────────
# .env.local (dev)      : NEXT_PUBLIC_* + SUPABASE_SERVICE_ROLE_KEY for scripts
# Vercel env            : NEXT_PUBLIC_* + SUPABASE_SERVICE_ROLE_KEY + FL_ADMIN_EMAILS
#                         + UPSTASH_* + POSTHOG
# GitHub Actions secrets: SUPABASE_SERVICE_ROLE_KEY, GOOGLE_PLACES_API_KEY,
#                         R2_*, TICKETMASTER_API_KEY, EVENTBRITE_PRIVATE_TOKEN,
#                         RESEND_API_KEY, EMAIL_FROM
# NEVER give a non-NEXT_PUBLIC_ key to the client bundle. The service role key
# and the Places key must never reach the browser.
